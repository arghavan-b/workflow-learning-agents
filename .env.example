# Copy this file to `.env` and fill in the keys you need:
#     cp .env.example .env
#
# `.env` is auto-loaded by demo2skill-parse-video (and is git-ignored, so your
# keys are never committed). Values already set in your shell take precedence.

# --- OpenAI  (used by: --client openai) -------------------------------------
OPENAI_API_KEY=
# Override the default vision model (default: gpt-4o):
# OPENAI_MODEL=gpt-4.1

# --- Anthropic  (used by: --client anthropic, and the --llm induction path) --
ANTHROPIC_API_KEY=

# --- HuggingFace  (ScreenVLM weights are public, so this is usually optional;
#     set it only if you hit rate limits or gated models) ---------------------
# HF_TOKEN=

# --- Local ScreenVLM via transformers  (--client auto uses this if set) ------
# SCREENVLM_MODEL=docling-project/ScreenVLM

# --- Quality-of-life: silence the tokenizers fork warning --------------------
# TOKENIZERS_PARALLELISM=false
